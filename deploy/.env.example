# 卷舍 SaaS · 部署环境变量样板。复制成 deploy/.env 后填真值(.env 不要提交)。
# docker compose 会自动读同目录 .env 注入 ${...}。

# 升级码校验密钥:必须与 nextapi-vps 上发卡服务(/opt/juanshe-activation)的同名密钥逐字一致,
# 否则用户的 Pro/Ultra 码在 SaaS 这边验不过。绝不写进仓库。
HARDWRITE_ACTIVATION_SECRET=

# 每批连写章数硬上限(共机 VPS 防一个用户挂机吃满 → 拖垮发卡服务)。默认 20,范围 [1,50]。
HARDWRITE_SAAS_MAX_BATCH_CHAPTERS=20
