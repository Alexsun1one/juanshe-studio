# 卷舍 SaaS · Web(studio-web)容器 —— Next.js standalone 输出(next.config 已 output:"standalone")。
# ⚠ 本机无 docker,未做本地 docker build 验证;但 standalone 产物已用 prod node 进程在 SaaS 模式下
# 本地烟测通过(浏览器→web→api 三跳 cookie OK)。容器只是把同一产物装进 node:22。

FROM node:22-slim AS builder
RUN corepack enable
WORKDIR /repo
COPY . .
# web 构建需要 core/engine 的类型/产物;全量装(含 devDep typescript,build 要 tsc)。
# --ignore-scripts 跳过 electron 二进制下载/sharp 原生编译(本镜像用不到);tsc/next 是纯 JS,正常工作。
# (不能用 --filter "studio-web..." —— 那样 core/engine 只装生产依赖,缺 tsc → build 失败。)
# pnpm 内容寻址 store 走 BuildKit 缓存挂载:依赖只下载一次、跨构建复用,扛 registry.npmjs.org
# 间歇性慢窗口。实测 npmmirror 从本 VPS 走 302 跳 CDN 反而更慢(1-20KiB/s),官方源平时 ~400KiB/s,
# 故保留官方源 + 缓存 + 放宽重试/超时即可。仅构建期拉包,不改锁文件与运行时。
RUN printf 'fetch-retries=5\nfetch-retry-maxtimeout=180000\nfetch-timeout=600000\nstore-dir=/pnpm-store\n' > .npmrc
RUN --mount=type=cache,id=pnpm-store,target=/pnpm-store pnpm install --frozen-lockfile --ignore-scripts
RUN pnpm --filter @juanshe/core build \
 && pnpm --filter @juanshe/engine build \
 && pnpm --filter studio-web build

FROM node:22-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
# Next standalone 布局:standalone 根含 packages/studio-web/server.js + 裁剪后的 node_modules;
# static 与 public 不在 standalone 里,需手动拷到对应子路径(outputFileTracingRoot=monorepo 根)。
COPY --from=builder /repo/packages/studio-web/.next/standalone ./
COPY --from=builder /repo/packages/studio-web/.next/static ./packages/studio-web/.next/static
COPY --from=builder /repo/packages/studio-web/public ./packages/studio-web/public
EXPOSE 3100
# server.js 读 PORT/HOSTNAME;JUANSHE_API_BASE 指向 api 服务(compose 注入)。
CMD ["node", "packages/studio-web/server.js"]
