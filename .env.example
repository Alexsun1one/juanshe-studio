# Juanshe Environment Configuration
# Copy to .env and fill in your values

# LLM Provider (openai, anthropic, custom)
JUANSHE_LLM_PROVIDER=openai

# API Base URL (OpenAI-compatible endpoint)
JUANSHE_LLM_BASE_URL=https://api.openai.com/v1

# API Key
JUANSHE_LLM_API_KEY=sk-your-key-here

# Model name
JUANSHE_LLM_MODEL=gpt-4o

# Desktop shell overrides (optional)
JUANSHE_WEB_PORT=3100
JUANSHE_API_PORT=4569
JUANSHE_WORKSPACE=
