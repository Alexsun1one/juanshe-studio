# Juanshe Environment Configuration
# Copy to .env and fill in your values

# LLM Provider (openai, anthropic, custom)
JUANSHE_LLM_PROVIDER=openai

# API Base URL (OpenAI-compatible endpoint)
JUANSHE_LLM_BASE_URL=https://api.openai.com/v1

# API Key
JUANSHE_LLM_API_KEY=sk-your-key-here

# Model name
JUANSHE_LLM_MODEL=gpt-4o

# Optional external search for radar and article research.
# Chat models such as DeepSeek can analyze provided context, but this backend
# needs a search provider key for live retrieval.
JUANSHE_SEARCH_PROVIDER=tavily
JUANSHE_SEARCH_API_KEY=

# Activation gate. The public verify URL checks signed JUAN codes without
# exposing the signing secret in the desktop package.
HARDWRITE_ACTIVATION_REQUIRED=1
HARDWRITE_ACTIVATION_VERIFY_URL=https://api.nextapi.top/juanshe-activation/verify

# Desktop shell overrides (optional)
JUANSHE_WEB_PORT=3100
JUANSHE_API_PORT=4569
JUANSHE_WORKSPACE=
