{
  "name": "juanshe-studio",
  "version": "1.3.10",
  "private": true,
  "description": "卷舍 · 本地 AI 小说写作工作台.",
  "keywords": [
    "ai-novel-writing",
    "ai-writing-agent",
    "novel-generator",
    "autonomous-writing",
    "litrpg",
    "progression-fantasy",
    "multi-agent",
    "creative-writing-ai",
    "editorial-workbench",
    "source-available"
  ],
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "package:mac": "node scripts/package-macos-app.mjs",
    "verify:publish-manifests": "node scripts/verify-no-workspace-protocol.mjs packages/core packages/studio",
    "release": "pnpm build && pnpm test"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  }
}
